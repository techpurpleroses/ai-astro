# =========================================================
# App
# =========================================================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Public URL used inside verification/reset emails.
# Set this to your real domain (or an ngrok URL in local testing) for cross-device auth links.
AUTH_PUBLIC_URL=

# =========================================================
# Supabase
# =========================================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional direct DB URL for server workers (if used later)
SUPABASE_DB_URL=

# =========================================================
# Astrology provider routing
# =========================================================
# Allowed values: astrology_api_io | astrologyapi | prokerala
ASTROLOGY_PROVIDER=astrology_api_io

# Primary provider (generic naming)
ASTROLOGY_API_BASE_URL=https://api.astrology-api.io
ASTROLOGY_API_KEY=

# Optional provider-specific keys
PROKERALA_API_BASE_URL=
PROKERALA_CLIENT_ID=
PROKERALA_CLIENT_SECRET=

ASTROLOGYAPI_BASE_URL=
ASTROLOGYAPI_USER_ID=
ASTROLOGYAPI_API_KEY=

# =========================================================
# OpenAI
# =========================================================
OPENAI_API_KEY=
OPENAI_ORG_ID=
OPENAI_PROJECT_ID=

# =========================================================
# Roboflow (Palm)
# =========================================================
ROBOFLOW_API_KEY=
ROBOFLOW_MODEL_ID=palm-lines-recognition-wemy5/1
ROBOFLOW_API_URL=https://serverless.roboflow.com

# =========================================================
# Stripe
# =========================================================
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Pricing source is DB-driven (billing.plan_catalog + billing.plan_price_versions).

# =========================================================
# Storage bucket config
# =========================================================
SUPABASE_BUCKET_PALM_SCANS=palm_scans
SUPABASE_BUCKET_SOULMATCH_IMAGES=soulmatch_images
SUPABASE_BUCKET_ASTRO_REPORTS=astro_reports

# =========================================================
# Palm feature flags (existing code support)
# =========================================================
PALM_DEBUG=1
NEXT_PUBLIC_PALM_DEBUG=1
PALM_INTERPRET_USE_OPENAI=1
PALM_INTERPRET_USE_MOCK=0
PALM_OPENAI_MODEL=gpt-4.1-mini
PALM_DATA_DIR=
