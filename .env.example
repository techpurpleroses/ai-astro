# =========================================================
# App
# =========================================================
NODE_ENV=development
ASTRO_DEBUG_LOGS=0
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Public URL used inside verification/reset emails.
# Set this to your real domain (or an ngrok URL in local testing) for cross-device auth links.
AUTH_PUBLIC_URL=
# Redirect path used in auth emails generated by API routes.
# Keep /auth/callback for default Supabase email templates (hash-token flow).
# Use /auth/confirm only after switching Supabase email templates to token_hash links.
AUTH_CALLBACK_PATH=/auth/callback

# =========================================================
# Supabase
# =========================================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional direct DB URL for server workers (if used later)
SUPABASE_DB_URL=

# =========================================================
# Astrology provider routing
# =========================================================
# Allowed values: astrology_api_io | astrologyapi | prokerala
ASTROLOGY_PROVIDER=astrology_api_io

# Primary provider (generic naming)
ASTROLOGY_API_BASE_URL=https://api.astrology-api.io
ASTROLOGY_API_KEY=

# Optional provider-specific keys
PROKERALA_API_BASE_URL=
PROKERALA_CLIENT_ID=
PROKERALA_CLIENT_SECRET=

ASTROLOGYAPI_BASE_URL=
ASTROLOGYAPI_USER_ID=
ASTROLOGYAPI_API_KEY=

# =========================================================
# OpenAI
# =========================================================
OPENAI_API_KEY=
OPENAI_ORG_ID=
OPENAI_PROJECT_ID=

# =========================================================
# Global location autocomplete (Mapbox)
# =========================================================
MAPBOX_ACCESS_TOKEN=

# =========================================================
# Roboflow (Palm)
# =========================================================
ROBOFLOW_API_KEY=
ROBOFLOW_MODEL_ID=palm-lines-recognition-wemy5/1
ROBOFLOW_API_URL=https://serverless.roboflow.com

# =========================================================
# Stripe (sandbox: use sk_test_* keys from Stripe Dashboard > Developers)
# =========================================================
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Webhook secret from: stripe listen --forward-to localhost:3000/api/stripe/webhook
# Or from Stripe Dashboard > Developers > Webhooks > Add endpoint
STRIPE_WEBHOOK_SECRET=
#
# Sandbox setup steps:
# 1. Create products in Stripe Dashboard (test mode):
#    - Pro monthly ₹799  → copy price ID → set in billing.plan_price_versions where lookup_key='pro_monthly_inr'
#    - Pro yearly ₹7990  → copy price ID → set in billing.plan_price_versions where lookup_key='pro_yearly_inr'
#    - Premium monthly ₹1999 → lookup_key='premium_monthly_inr'
#    - Premium yearly ₹19990 → lookup_key='premium_yearly_inr'
#    - Credit pack 50 (₹499, one-time)  → lookup_key='credits_50_inr'
#    - Credit pack 100 (₹899, one-time) → lookup_key='credits_100_inr'
#    - Credit pack 200 (₹1499, one-time) → lookup_key='credits_200_inr'
# 2. Run: stripe listen --forward-to localhost:3000/api/stripe/webhook
# 3. Copy the webhook signing secret (whsec_...) to STRIPE_WEBHOOK_SECRET
# 4. Run migration 20260319000000 to add stripe_customer_id to identity.profiles
# Pricing source is DB-driven (billing.plan_catalog + billing.plan_price_versions).

# =========================================================
# Storage bucket config
# =========================================================
SUPABASE_BUCKET_PALM_SCANS=palm_scans
SUPABASE_BUCKET_SOULMATCH_IMAGES=soulmatch_images
SUPABASE_BUCKET_ASTRO_REPORTS=astro_reports

# =========================================================
# Palm feature flags
# =========================================================
PALM_INTERPRET_USE_OPENAI=1
PALM_INTERPRET_USE_MOCK=0
PALM_OPENAI_MODEL=gpt-4.1-mini
PALM_DATA_DIR=

# =========================================================
# Sentry (error monitoring)
# =========================================================
# DSN from: sentry.io > Project > Settings > Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=
# Org and project slugs from your Sentry organization
SENTRY_ORG=
SENTRY_PROJECT=
# Auth token for source map uploads: sentry.io > Settings > Auth Tokens
# Required scopes: project:releases, org:read
SENTRY_AUTH_TOKEN=
