            "text": "[{\"id\":7,\"category\":\"create_your_future\",\"lang_id\":1,\"name\":\"How to Maintain a Long-Distance Relationship\",\"short_name\":\"Maintain a Relationship\",\"description\":\"<p>Long-distance love comes with their own specific difficulties. Look into practices that help you overcome challenges and make relationships absolutely succeed</p>\",\"image\":\"https://astroline.fsn1.your-objectstorage.com/uploads/courses/img-1-small@3x.png_image_1600084716.png\",\"users_count\":30134,\"sessions_count\":7,\"short_quiz_questions_count\":3,\"is_active\":1,\"image_denim\":\"https://astroline.fsn1.your-objectstorage.com/uploads/courses/img-small-long-distance-relationships@3x.png_image_denim_1621330731.png\",\"slug\":\"long_distance_relationship\",\"has_content\":true,\"sessions_completed_count\":0,\"questions\":[{\"id\":2,\"course_id\":7,\"text\":\"<p>Have you been in a relationship before?</p>\",\"description\":\"<p>Please answer the question to get advice from our experts</p>\",\"order\":1,\"multi_select\":0,\"answers\":[{\"id\":2,\"question_id\":2,\"text\":\"Yes\"},{\"id\":3,\"question_id\":2,\"text\":\"No\"}]},{\"id\":3,\"course_id\":7,\"text\":\"<p>Are you currently married (or equivalent) to your partner?</p>\",\"description\":\"<p>Tell us a bit about your relationship, so we can prepare a unique guide for you</p>\",\"order\":2,\"multi_select\":1,\"answers\":[{\"id\":4,\"question_id\":3,\"text\":\"Yes\"},{\"id\":5,\"question_id\":3,\"text\":\"No\"}]},{\"id\":4,\"course_id\":7,\"text\":\"<p>What caused you to start a long-distance relationship?</p>\",\"description\":\"<p>What you're feeling? Tell us, and we help you make a relationship stronger</p>\",\"order\":3,\"multi_select\":1,\"answers\":[{\"id\":6,\"question_id\":4,\"text\":\"Military service\"},{\"id\":7,\"question_id\":4,\"text\":\"Pandemic\"},{\"id\":8,\"question_id\":4,\"text\":\"Work\"},{\"id\":9,\"question_id\":4,\"text\":\"Study\"},{\"id\":10,\"question_id\":4,\"text\":\"Online relationship\"},{\"id\":11,\"question_id\":4,\"text\":\"Travel\"},{\"id\":12,\"question_id\":4,\"text\":\"Own decision\"},{\"id\":13,\"question_id\":4,\"text\":\"Business trip\"}]},{\"id\":10,\"course_id\":7,\"text\":\"<p>How long have you been in a long-distance relationship?</p>\",\"description\":\"<p>Please answer the question to get advice from our experts</p>\",\"order\":4,\"multi_select\":0,\"answers\":[{\"id\":36,\"question_id\":10,\"text\":\"Less than a month\"},{\"id\":37,\"question_id\":10,\"text\":\"1-3 months\"},{\"id\":38,\"question_id\":10,\"text\":\"4-12 months\"},{\"id\":39,\"question_id\":10,\"text\":\"More than a year\"}]},{\"id\":11,\"course_id\":7,\"text\":\"<p>What is the most comfortable way to communicate with your partner?</p>\",\"description\":\"<p>Tell us a bit about your relationship, so we can prepare a unique guide for you</p>\",\"order\":5,\"multi_select\":0,\"answers\":[{\"id\":40,\"question_id\":11,\"text\":\"Texting\"},{\"id\":41,\"question_id\":11,\"text\":\"Video calling\"},{\"id\":42,\"question_id\":11,\"text\":\"Voice calling\"}]}]},{\"id\":8,\"category\":\"create_your_future\",\"lang_id\":1,\"name\":\"How to Build a Healthy Relationship\",\"short_name\":\"Healthy Relationship\",\"description\":\"<p>This course will help you discover ways to keep your relationship strong and healthy.</p>\",\"image\":\"https://astroline.fsn1.your-objectstorage.com/uploads/courses/-g-Img_2_small.png_image_1597824755.png\",\"users_count\":51628,\"sessions_count\":8,\"short_quiz_questions_count\":3,\"is_active\":1,\"image_denim\":\"https://astroline.fsn1.your-objectstorage.com/uploads/courses/img-small-how-to-build-a-healthy-relationship@3x.png_image_denim_1621330775.png\",\"slug\":\"healthy_relationship\",\"has_content\":true,\"sessions_completed_count\":0,\"questions\":[{\"id\":12,\"course_id\":8,\"text\":\"<p>How long have you been in a relationship?</p>\",\"description\":\"<p>Please answer the question to get advice from our experts</p>\",\"order\":1,\"multi_select\":0,\"answers\":[{\"id\":43,\"question_id\":12,\"text\":\"Less than a month\"},{\"id\":44,\"question_id\":12,\"text\":\"1-3 months\"},{\"id\":45,\"question_id\":12,\"text\":\"4-12 months\"},{\"id\":46,\"question_id\":12,\"text\":\"More than a year\"}]},{\"id\":13,\"course_id\":8,\"text\":\"<p>Is this relationship headed in the right direction?</p>\",\"description\":\"<p>Tell us a bit about your relationship, so we can prepare a unique guide for you</p>\",\"order\":2,\"multi_select\":0,\"answers\":[{\"id\":47,\"question_id\":13,\"text\":\"Yes\"},{\"id\":48,\"question_id\":13,\"text\":\"No\"}]},{\"id\":14,\"course_id\":8,\"text\":\"<p>What happens when you disagree with your partner?</p>\",\"description\":\"<p>What you're feeling? Tell us, and we help you make a relationship stronger</p>\",\"order\":3,\"multi_select\":1,\"answers\":[{\"id\":49,\"question_id\":14,\"text\":\"Don't listen\"},{\"id\":50,\"question_id\":14,\"text\":\"Open to change\"},{\"id\":51,\"question_id\":14,\"text\":\"Make compromises\"},{\"id\":52,\"question_id\":14,\"text\":\"Get nervous\"},{\"id\":53,\"question_id\":14,\"text\":\"Interrupt my partner\"},{\"id\":54,\"question_id\":14,\"text\":\"Hold a grudge\"},{\"id\":55,\"question_id\":14,\"text\":\"Keep pushing my point\"},{\"id\":56,\"question_id\":14,\"text\":\"Looking for solutions\"}]},{\"id\":15,\"course_id\":8,\"text\":\"What is the most comfortable way to communicate with your partner?\",\"description\":\"<p>Please answer the question to get advice from our experts</p>\",\"order\":4,\"multi_select\":0,\"answers\":[{\"id\":57,\"question_id\":15,\"text\":\"Texting\"},{\"id\":58,\"question_id\":15,\"text\":\"Video calling\"},{\"id\":59,\"question_id\":15,\"text\":\"Voice calling\"}]},{\"id\":16,\"course_id\":8,\"text\":\"Does your relationship feel lopsided?\",\"description\":\"<p>Tell us a bit about your relationship, so we can prepare a unique guide for you</p>\",\"order\":5,\"multi_select\":0,\"answers\":[{\"id\":60,\"question_id\":16,\"text\":\"Yes\"},{\"id\":61,\"question_id\":16,\"text\":\"No\"}]}]},{\"id\":9,\"category\":\"self_care\",\"lang_id\":1,\"name\":\"How to Become Better at Dating\",\"short_name\":\"Improve My Dating Life\",\"description\":\"\",\"image\":\"https://astroline.fsn1.your-objectstorage.com/uploads/courses/-g-Img_9_small.png_image_1597824784.png\",\"users_count\":217834,\"sessions_count\":8,\"short_quiz_questions_count\":3,\"is_active\":1,\"image_denim\":\"https://astroline.fsn1.your-objectstorage.com/uploads/courses/img-small-how-to-date@3x.png_image_denim_1621330853.png\",\"slug\":\"better_at_dating\",\"has_content\":true,\"sessions_completed_count\":0,\"questions\":[{\"id\":17,\"course_id\":9,\"text\":\"<p>What do you want to do on a first date?</p>\",\"description\":\"<p>Please answer the question to get advice from our experts</p>\",\"order\":1,\"multi_select\":1,\"answers\":[{\"id\":62,\"question_id\":17,\"text\":\"Dance at a club\"},{\"id\":63,\"question_id\":17,\"text\":\"Go cycling\"},{\"id\":64,\"question_id\":17,\"text\":\"Go to a movie\"},{\"id\":65,\"question_id\":17,\"text\":\"Online dating\"},{\"id\":66,\"question_id\":17,\"text\":\"Go ice skating\"},{\"id\":67,\"question_id\":17,\"text\":\"Go to a fancy restaurant\"},{\"id\":68,\"question_id\":17,\"text\":\"Go bowling\"},{\"id\":69,\"question_id\":17,\"text\":\"Walk in the park\"}]},{\"id\":18,\"course_id\":9,\"text\":\"<p>Is it easy to find people that you think are beautiful?</p>\",\"description\":\"<p>Take the survey to get useful tips</p>\",\"order\":2,\"multi_select\":0,\"answers\":[{\"id\":70,\"question_id\":18,\"text\":\"Yes\"},{\"id\":71,\"question_id\":18,\"text\":\"No\"}]},{\"id\":19,\"course_id\":9,\"text\":\"<p>What happens when you disagree with your partner?</p>\",\"description\":\"<p>Tell us about your feelings and emotions and get helpful advice from our experts</p>\",\"order\":3,\"multi_select\":0,\"answers\":[{\"id\":72,\"question_id\":19,\"text\":\"Don't listen\"},{\"id\":73,\"question_id\":19,\"text\":\"Open to change\"},{\"id\":74,\"question_id\":19,\"text\":\"Make compromises\"},{\"id\":75,\"question_id\":19,\"text\":\"Get nervous\"},{\"id\":76,\"question_id\":19,\"text\":\"Interrupt my partner\"},{\"id\":77,\"question_id\":19,\"text\":\"Hold a grudge\"},{\"id\":78,\"question_id\":19,\"text\":\"Keep pushing my point\"},{\"id\":79,\"question_id\":19,\"text\":\"Looking for solutions\"}]},{\"id\":20,\"course_id\":9,\"text\":\"Do you truly love yourself?\",\"description\":\"<p>Tell us about yourself so that we can prepare a list of recommendations for you</p>\",\"order\":4,\"multi_select\":0,\"answers\":[{\"id\":80,\"question_id\":20,\"text\":\"Yes\"},{\"id\":81,\"question_id\":20,\"text\":\"No\"}]},{\"id\":21,\"course_id\":9,\"text\":\"<p>Do you have any hobbies or interests?</p>\",\"description\":\"Take the survey to get useful tips\",\"order\":5,\"multi_select\":0,\"answers\":[{\"id\":82,\"question_id\":21,\"text\":\"Yes\"},{\"id\":83,\"question_id\":21,\"text\":\"No\"}]}]},{\"id\":13,\"category\":\"self_care\",\"lang_id\":1,\"name\":\"How To Find True Love\",\"short_name\":\"Find True Love\",\"description\":\"<p>In this powerful and emotional program, you will learn how to build harmonious relationships and find happiness in love. </p>\",\"image\":\"https://astroline.fsn1.your-objectstorage.com/uploads/courses/-g-Img_5_small.png_image_1597824891.png\",\"users_count\":123836,\"sessions_count\":8,\"short_quiz_questions_count\":3,\"is_active\":1,\"image_denim\":\"https://astroline.fsn1.your-objectstorage.com/uploads/courses/img-small-how-to-find-true-love@3x.png_image_denim_1621330903.png\",\"slug\":\"find_true_love\",\"has_content\":true,\"sessions_completed_count\":0,\"questions\":[{\"id\":27,\"course_id\":13,\"text\":\"<p>Have you ever been in relationship?</p>\",\"description\":\"<p>Please answer the question to get advice from our experts</p>\",\"order\":1,\"multi_select\":0,\"answers\":[{\"id\":118,\"question_id\":27,\"text\":\"Yes\"},{\"id\":119,\"question_id\":27,\"text\":\"No\"}]},{\"id\":28,\"course_id\":13,\"text\":\"<p>Do you want to get married?</p>\",\"description\":\"<p>Tell us a bit about your relationship, so we can prepare a unique guide for you</p>\",\"order\":2,\"multi_select\":0,\"answers\":[{\"id\":120,\"question_id\":28,\"text\":\"Yes\"},{\"id\":121,\"question_id\":28,\"text\":\"No\"}]},{\"id\":29,\"course_id\":13,\"text\":\"<p>Which one of these is the most essential to you?</p>\",\"description\":\"<p>What you're feeling? Tell us, and we help you make a relationship stronger</p>\",\"order\":3,\"multi_select\":0,\"answers\":[{\"id\":122,\"question_id\":29,\"text\":\"Career\"},{\"id\":123,\"question_id\":29,\"text\":\"Family\"},{\"id\":124,\"question_id\":29,\"text\":\"Education\"},{\"id\":125,\"question_id\":29,\"text\":\"Achievements\"}]},{\"id\":30,\"course_id\":13,\"text\":\"<p>What do you want to do on a first date?</p>\",\"description\":\"<p>Please answer the question to get advice from our experts</p>\",\"order\":4,\"multi_select\":0,\"answers\":[{\"id\":126,\"question_id\":30,\"text\":\"Go to a club\"},{\"id\":127,\"question_id\":30,\"text\":\"Go cycling\"},{\"id\":128,\"question_id\":30,\"text\":\"Go to a movie\"},{\"id\":129,\"question_id\":30,\"text\":\"Online dating\"},{\"id\":130,\"question_id\":30,\"text\":\"Go ice skating\"},{\"id\":131,\"question_id\":30,\"text\":\"Go to a restaurant\"},{\"id\":132,\"question_id\":30,\"text\":\"Go bowling\"},{\"id\":133,\"question_id\":30,\"text\":\"Walk in the park\"}]},{\"id\":31,\"course_id\":13,\"text\":\"Is it easy to find people that you think are beautiful?\",\"description\":\"<p>Tell us a bit about your relationship, so we can prepare a unique guide for you</p>\",\"order\":5,\"multi_select\":0,\"answers\":[{\"id\":134,\"question_id\":31,\"text\":\"Yes\"},{\"id\":135,\"question_id\":31,\"text\":\"No\"}]}]},{\"id\":17,\"category\":\"career_and_money\",\"lang_id\":1,\"name\":\"How to Manage Your Money\",\"short_name\":\"Mo