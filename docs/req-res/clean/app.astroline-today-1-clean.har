      {
        "_connectionId": "6013",
        "cache": {},
        "request": {
          "method": "GET",
          "url": "https://astrology.astroline.app/api/v1/birthchart/planets",
          "httpVersion": "http/2.0",
          "headers": [
            {
              "name": "content-type",
              "value": "application/json; charset=UTF-8"
