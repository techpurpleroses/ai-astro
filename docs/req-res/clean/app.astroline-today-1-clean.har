            "size": 4577,
            "mimeType": "application/json",
            "text": "{\"success\":true,\"data\":{\"today\":[{\"natalPlanet\":\"pluto\",\"transitPlanet\":\"sun\",\"aspect\":\"square\",\"influence\":\"negative\",\"start\":\"2026-02-25T00:00:00+05:30\",\"end\":\"2026-03-06T00:00:00+05:30\"},{\"natalPlanet\":\"jupiter\",\"transitPlanet\":\"moon\",\"aspect\":\"square\",\"influence\":\"negative\",\"start\":\"2026-02-27T00:00:00+05:30\",\"end\":\"2026-02-28T00:00:00+05:30\"},{\"natalPlanet\":\"mars\",\"transitPlanet\":\"mars\",\"aspect\":\"conjunction\",\"influence\":\"blended\",\"start\":\"2026-02-23T00:00:00+05:30\",\"end\":\"2026-03-06T00:00:00+05:30\"},{\"natalPlanet\":\"sun\",\"transitPlanet\":\"sun\",\"aspect\":\"sextile\",\"influence\":\"positive\",\"start\":\"2026-02-24T00:00:00+05:30\",\"end\":\"2026-03-05T00:00:00+05:30\"}],\"tomorrow\":[{\"natalPlanet\":\"sun\",\"transitPlanet\":\"sun\",\"aspect\":\"sextile\",\"influence\":\"positive\",\"start\":\"2026-02-24T00:00:00+05:30\",\"end\":\"2026-03-05T00:00:00+05:30\"},{\"natalPlanet\":\"mercury\",\"transitPlanet\":\"mars\",\"aspect\":\"sextile\",\"influence\":\"positive\",\"start\":\"2026-02-28T00:00:00+05:30\",\"end\":\"2026-03-11T00:00:00+05:30\"},{\"natalPlanet\":\"moon\",\"transitPlanet\":\"moon\",\"aspect\":\"square\",\"influence\":\"negative\",\"start\":\"2026-03-01T00:00:00+05:30\",\"end\":\"2026-03-01T00:00:00+05:30\"},{\"natalPlanet\":\"venus\",\"transitPlanet\":\"mars\",\"aspect\":\"square\",\"influence\":\"negative\",\"start\":\"2026-02-27T00:00:00+05:30\",\"end\":\"2026-03-10T00:00:00+05:30\"}],\"week\":[{\"natalPlanet\":\"venus\",\"transitPlanet\":\"moon\",\"aspect\":\"opposition\",\"influence\":\"negative\",\"start\":\"2026-02-23T00:00:00+05:30\",\"end\":\"2026-02-25T00:00:00+05:30\"},{\"natalPlanet\":\"moon\",\"transitPlanet\":\"venus\",\"aspect\":\"trine\",\"influence\":\"positive\",\"start\":\"2026-02-17T00:00:00+05:30\",\"end\":\"2026-02-27T00:00:00+05:30\"},{\"natalPlanet\":\"mercury\",\"transitPlanet\":\"mars\",\"aspect\":\"sextile\",\"influence\":\"positive\",\"start\":\"2026-02-28T00:00:00+05:30\",\"end\":\"2026-03-11T00:00:00+05:30\"},{\"natalPlanet\":\"venus\",\"transitPlanet\":\"mars\",\"aspect\":\"square\",\"influence\":\"negative\",\"start\":\"2026-02-27T00:00:00+05:30\",\"end\":\"2026-03-10T00:00:00+05:30\"},{\"natalPlanet\":\"moon\",\"transitPlanet\":\"moon\",\"aspect\":\"trine\",\"influence\":\"positive\",\"start\":\"2026-02-27T00:00:00+05:30\",\"end\":\"2026-02-27T00:00:00+05:30\"},{\"natalPlanet\":\"pluto\",\"transitPlanet\":\"sun\",\"aspect\":\"square\",\"influence\":\"negative\",\"start\":\"2026-02-25T00:00:00+05:30\",\"end\":\"2026-03-06T00:00:00+05:30\"}],\"month\":[{\"natalPlanet\":\"neptune\",\"transitPlanet\":\"pluto\",\"aspect\":\"conjunction\",\"influence\":\"blended\",\"start\":\"2023-12-20T00:00:00+05:30\",\"end\":\"2028-03-09T00:00:00+05:30\"},{\"natalPlanet\":\"mercury\",\"transitPlanet\":\"saturn\",\"aspect\":\"square\",\"influence\":\"negative\",\"start\":\"2026-01-25T00:00:00+05:30\",\"end\":\"2026-02-14T00:00:00+05:30\"},{\"natalPlanet\":\"venus\",\"transitPlanet\":\"saturn\",\"aspect\":\"trine\",\"influence\":\"positive\",\"start\":\"2026-01-13T00:00:00+05:30\",\"end\":\"2026-02-14T00:00:00+05:30\"},{\"natalPlanet\":\"moon\",\"transitPlanet\":\"jupiter\",\"aspect\":\"trine\",\"influence\":\"positive\",\"start\":\"2026-01-03T00:00:00+05:30\",\"end\":\"2026-05-14T00:00:00+05:30\"},{\"natalPlanet\":\"venus\",\"transitPlanet\":\"pluto\",\"aspect\":\"sextile\",\"influence\":\"positive\",\"start\":\"2022-12-10T00:00:00+05:30\",\"end\":\"2027-02-23T00:00:00+05:30\"},{\"natalPlanet\":\"venus\",\"transitPlanet\":\"uranus\",\"aspect\":\"opposition\",\"influence\":\"negative\",\"start\":\"2025-04-25T00:00:00+05:30\",\"end\":\"2027-06-18T00:00:00+05:30\"}],\"year\":[{\"natalPlanet\":\"venus\",\"transitPlanet\":\"saturn\",\"aspect\":\"trine\",\"influence\":\"positive\",\"start\":\"2026-01-13T00:00:00+05:30\",\"end\":\"2026-02-14T00:00:00+05:30\"},{\"natalPlanet\":\"mars\",\"transitPlanet\":\"jupiter\",\"aspect\":\"opposition\",\"influence\":\"negative\",\"start\":\"2026-10-15T00:00:00+05:30\",\"end\":\"2027-02-11T00:00:00+05:30\"},{\"natalPlanet\":\"uranus\",\"transitPlanet\":\"jupiter\",\"aspect\":\"opposition\",\"influence\":\"negative\",\"start\":\"2026-08-15T00:00:00+05:30\",\"end\":\"2026-09-27T00:00:00+05:30\"},{\"natalPlanet\":\"jupiter\",\"transitPlanet\":\"jupiter\",\"aspect\":\"square\",\"influence\":\"negative\",\"start\":\"2026-05-14T00:00:00+05:30\",\"end\":\"2026-06-30T00:00:00+05:30\"},{\"natalPlanet\":\"jupiter\",\"transitPlanet\":\"jupiter\",\"aspect\":\"trine\",\"influence\":\"positive\",\"start\":\"2026-10-09T00:00:00+05:30\",\"end\":\"2027-02-19T00:00:00+05:30\"},{\"natalPlanet\":\"venus\",\"transitPlanet\":\"uranus\",\"aspect\":\"opposition\",\"influence\":\"negative\",\"start\":\"2025-04-25T00:00:00+05:30\",\"end\":\"2027-06-18T00:00:00+05:30\"},{\"natalPlanet\":\"neptune\",\"transitPlanet\":\"pluto\",\"aspect\":\"conjunction\",\"influence\":\"blended\",\"start\":\"2023-12-20T00:00:00+05:30\",\"end\":\"2028-03-09T00:00:00+05:30\"},{\"natalPlanet\":\"venus\",\"transitPlanet\":\"pluto\",\"aspect\":\"sextile\",\"influence\":\"positive\",\"start\":\"2022-12-10T00:00:00+05:30\",\"end\":\"2027-02-23T00:00:00+05:30\"}]},\"errors\":[]}"
