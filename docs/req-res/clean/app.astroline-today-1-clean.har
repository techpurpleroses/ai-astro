            "size": 9884,
            "mimeType": "application/json",
            "text": "[{\"date\":\"2026-02-26\",\"status\":\"favorable\",\"ideas\":{\"items\":[{\"id\":21,\"content\":\"Go to an amusement park\",\"lang_id\":1},{\"id\":30,\"content\":\"Go ice-skating\",\"lang_id\":1},{\"id\":32,\"content\":\"Visit a museum\",\"lang_id\":1},{\"id\":55,\"content\":\"Go to a shooting range\",\"lang_id\":1},{\"id\":58,\"content\":\"Play basketball\",\"lang_id\":1}],\"tooltip\":\"\"},\"tips\":{\"items\":[{\"id\":9,\"is_positive\":true,\"content\":\"Believe in yourself\"},{\"id\":13,\"is_positive\":true,\"content\":\"Be in the moment\"},{\"id\":17,\"is_positive\":true,\"content\":\"Choose a comfortable place for a date\"},{\"id\":31,\"is_positive\":false,\"content\":\"Don’t be rude to service personnel\"},{\"id\":224,\"is_positive\":false,\"content\":\"Don't gesticulate intensely\"},{\"id\":225,\"is_positive\":false,\"content\":\"Don't make dirty jokes\"}],\"tooltip\":\"Transits show how planets influence your daily life\",\"best_option\":null},\"questions\":{\"items\":[{\"id\":11,\"content\":\"What’s the scariest thing you ever encountered as a kid?\",\"lang_id\":1},{\"id\":13,\"content\":\"What were your parents like when you were growing up?\",\"lang_id\":1},{\"id\":16,\"content\":\"If you could take the whole month off, how would you spend your time?\",\"lang_id\":1},{\"id\":25,\"content\":\"When’s the last time you did something for the first time? What was it and how did you feel about it?\",\"lang_id\":1},{\"id\":29,\"content\":\"If you could live anywhere in the world, where would you move and why?\",\"lang_id\":1}],\"tooltip\":\"Your astrology chart holds the key to your path\"},\"food\":{\"items\":{\"id\":8,\"type\":\"Pizza, Italian cuisine\",\"description\":\"Pizza is usually eaten with friends and family, so such a choice subconsciously helps even strangers feel like close people.\",\"lang_id\":1},\"tooltip\":\"Biorhythm shows how we are influenced by physical, emotional, and intellectual cycles\"},\"outfit\":{\"items\":{\"outfit\":{\"id\":6,\"lang_id\":1,\"style\":\"Pajama style\",\"description\":\"A comfortable and sophisticated style that's perfect for a date at home. A distinctive feature is a simple silhouette of a free cut, slightly reminiscent of underwear. Soft fabrics (satin, silk, cotton) will create a feeling of luxury and freedom.\"},\"colors\":[16,12,10]},\"tooltip\":\"Zodiac signs influence our personality\"},\"physical_chemistry\":{\"items\":[{\"name\":\"Kissing\",\"value\":1},{\"name\":\"Hugging\",\"value\":5},{\"name\":\"Holding hands\",\"value\":3},{\"name\":\"Cuddling\",\"value\":2},{\"name\":\"Stroking\",\"value\":5},{\"name\":\"Sex\",\"value\":2}],\"tooltip\":\"The compatibility report shows love potential between you and your partner\"}},{\"date\":\"2026-02-27\",\"status\":\"favorable\",\"ideas\":{\"items\":[{\"id\":14,\"content\":\"Go to a local festival\",\"lang_id\":1},{\"id\":18,\"content\":\"Visit a dog park\",\"lang_id\":1},{\"id\":29,\"content\":\"Visit a zoo\",\"lang_id\":1},{\"id\":43,\"content\":\"Rent a kayak or canoe\",\"lang_id\":1},{\"id\":44,\"content\":\"Walk on the beach\",\"lang_id\":1}],\"tooltip\":\"\"},\"tips\":{\"items\":[{\"id\":15,\"is_positive\":true,\"content\":\"Offer to pay\"},{\"id\":198,\"is_positive\":true,\"content\":\"Ask the other person about goals in life\"},{\"id\":203,\"is_positive\":true,\"content\":\"Listen carefully\"},{\"id\":40,\"is_positive\":false,\"content\":\"Don't ignore the warning signs\"},{\"id\":43,\"is_positive\":false,\"content\":\"Don't talk about finance\"},{\"id\":213,\"is_positive\":false,\"content\":\"Don't look with interest at other women (men)\"}],\"tooltip\":\"Transits show how planets influence your daily life\",\"best_option\":null},\"questions\":{\"items\":[{\"id\":8,\"content\":\"What were some of your favorite things growing up?\",\"lang_id\":1},{\"id\":20,\"content\":\"What’s one thing you wish you could spend more time doing?\",\"lang_id\":1},{\"id\":30,\"content\":\"What are you looking for in a partner? Do you have any clue as to why your previous relationships didn’t work out?\",\"lang_id\":1},{\"id\":38,\"content\":\"What’s the worst experience you’ve ever had on a date?\",\"lang_id\":1},{\"id\":46,\"content\":\"Are you an animal lover?\",\"lang_id\":1}],\"tooltip\":\"Your astrology chart holds the key to your path\"},\"food\":{\"items\":{\"id\":11,\"type\":\"Plov, Uzbek cuisine\",\"description\":\"\\\"Uzbek aphrodisiac\\\" has a rich spicy pungent taste. It contains cumin and hot peppers - energizing spices. And, although this choice may seem unusual for a date, professionally prepared pilaf will not leave anyone indifferent.\",\"lang_id\":1},\"tooltip\":\"Biorhythm shows how we are influenced by physical, emotional, and intellectual cycles\"},\"outfit\":{\"items\":{\"outfit\":{\"id\":5,\"lang_id\":1,\"style\":\"Romance\",\"description\":\"This style suggests sophistication, lightness and sublimity. Key items: jackets, V-necks, breeches, skins, scarf, shoes or sneakers.\"},\"colors\":[25,11,28]},\"tooltip\":\"Zodiac signs influence our personality\"},\"physical_chemistry\":{\"items\":[{\"name\":\"Kissing\",\"value\":5},{\"name\":\"Hugging\",\"value\":4},{\"name\":\"Holding hands\",\"value\":4},{\"name\":\"Cuddling\",\"value\":3},{\"name\":\"Stroking\",\"value\":3},{\"name\":\"Sex\",\"value\":2}],\"tooltip\":\"The compatibility report shows love potential between you and your partner\"}},{\"date\":\"2026-02-28\",\"status\":\"favorable\",\"ideas\":{\"items\":[{\"id\":16,\"content\":\"Go to a comedy club\",\"lang_id\":1},{\"id\":19,\"content\":\"Visit a \\\"live theatre\\\"\",\"lang_id\":1},{\"id\":32,\"content\":\"Visit a museum\",\"lang_id\":1},{\"id\":42,\"content\":\"Throw a casino night\",\"lang_id\":1},{\"id\":45,\"content\":\"Watch the sunrise/sunset\",\"lang_id\":1}],\"tooltip\":\"\"},\"tips\":{\"items\":[{\"id\":26,\"is_positive\":true,\"content\":\"Treat yourself with humor\"},{\"id\":200,\"is_positive\":true,\"content\":\"Smile\"},{\"id\":205,\"is_positive\":true,\"content\":\"Eat and drink gently\"},{\"id\":29,\"is_positive\":false,\"content\":\"Don't discuss your ex\"},{\"id\":212,\"is_positive\":false,\"content\":\"Don't be taciturn\"},{\"id\":214,\"is_positive\":false,\"content\":\"Don't share your feelings for your ex\"}],\"tooltip\":\"Transits show how planets influence your daily life\",\"best_option\":null},\"questions\":{\"items\":[{\"id\":7,\"content\":\"Where did you grow up?\",\"lang_id\":1},{\"id\":25,\"content\":\"When’s the last time you did something for the first time? What was it and how did you feel about it?\",\"lang_id\":1},{\"id\":29,\"content\":\"If you could live anywhere in the world, where would you move and why?\",\"lang_id\":1},{\"id\":52,\"content\":\"What is something you're passionate about?\",\"lang_id\":1},{\"id\":56,\"content\":\"What is something good that happened to you today?\",\"lang_id\":1}],\"tooltip\":\"Your astrology chart holds the key to your path\"},\"food\":{\"items\":{\"id\":14,\"type\":\"Crepes with sweet filling, French cuisine\",\"description\":\"Delicate dish with French charm. The best choice is crepes with banana filling and chocolate sauce.\",\"lang_id\":1},\"tooltip\":\"Biorhythm shows how we are influenced by physical, emotional, and intellectual cycles\"},\"outfit\":{\"items\":{\"outfit\":{\"id\":6,\"lang_id\":1,\"style\":\"Pajama style\",\"description\":\"A comfortable and sophisticated style that's perfect for a date at home. A distinctive feature is a simple silhouette of a free cut, slightly reminiscent of underwear. Soft fabrics (satin, silk, cotton) will create a feeling of luxury and freedom.\"},\"colors\":[16,12,10]},\"tooltip\":\"Zodiac signs influence our personality\"},\"physical_chemistry\":{\"items\":[{\"name\":\"Kissing\",\"value\":4},{\"name\":\"Hugging\",\"value\":1},{\"name\":\"Holding hands\",\"value\":5},{\"name\":\"Cuddling\",\"value\":1},{\"name\":\"Stroking\",\"value\":1},{\"name\":\"Sex\",\"value\":5}],\"tooltip\":\"The compatibility report shows love potential between you and your partner\"}},{\"date\":\"2026-03-01\",\"status\":\"favorable\",\"ideas\":{\"items\":[{\"id\":11,\"content\":\"Go for ice cream\",\"lang_id\":1},{\"id\":29,\"content\":\"Visit a zoo\",\"lang_id\":1},{\"id\":36,\"content\":\"Go the planetarium\",\"lang_id\":1},{\"id\":44,\"content\":\"Walk on the beach\",\"lang_id\":1},{\"id\":54,\"content\":\"Try a new fancy coffee\",\"lang_id\":1}],\"tooltip\":\"\"},\"tips\":{\"items\":[{\"id\":16,\"is_positive\":true,\"content\":\"Be positive\"},{\"id\":20,\"is_positive\":true,\"content\":\"Be honest\"},{\"id\":201,\"is_positive\":true,\"content\":\"Try to notice changes in a person's mood\"},{\"id\":32,\"is_positive\":false,\"content\":\"Don't chase your partner on social media\"},{\"id\":220,\"is_positive\":false,\"content\":\"Don't gossip\"},{\"id\":227,\"is_positive\":false,\"content\":\"Do not use foul language\"}],\"tooltip\":\"Transits show how planets influence your daily life\",\"best_option\":null},\"questions\":{\"items\":[{\"id\":23,\"content\":\"If you could become a master of something, what would that something be and why?\",\"lang_id\":1},{\"id\":27,\"content\":\"How did you meet your best friend and why do you think your relationship has worked out so well?\",\"lang_id\":1},{\"id\":29,\"content\":\"If you could live anywhere in the world, where would you move and why?\",\"lang_id\":1},{\"id\":56,\"content\":\"What is something good that happened to you today?\",\"lang_id\":1},{\"id\":58,\"content\":\"What do you do to wake yourself up in the morning?\",\"lang_id\":1}],\"tooltip\":\"Your astrology chart holds the key to your path\"},\"food\":{\"items\":{\"id\":9,\"type\":\"Tom yum soup, Thai cuisine\",\"description\":\"The \\\"business card\\\" of Thai cuisine: a harmonious combination of flavors, exotic ingredients, a unique bouquet that will turn a date into a bright and unforgettable event.\",\"lang_id\":1},\"tooltip\":\"Biorhythm shows how we are influenced by physical, emotional, and intellectual cycles\"},\"outfit\":{\"items\":{\"outfit\":{\"id\":16,\"lang_id\":1,\"style\":\"Boho\",\"description\":\"Going to a concert, music festival or beach party? Then choose the style of freedom-loving and creative people. Boho does not imply excessive sexuality and severity. This style is characterized by a certain carelessness: wide, loose silhouettes, natural fabrics, headbands and lace.\"},\"colors\":[16,12,10]},\"tooltip\":\"Zodiac signs influence our personality\"},\"physical_chemistry\":{\"items\":[{\"name\":\"Kissing\",\"value\":5},{\"name\":\"Hugging\",\"value\":3},{\"name\":\"Holding hands\",\"value\":4},{\"name\":\"Cuddling\",\"value\":3},{\"name\":\"Stroking\",\"value\":4},{\"name\":\"Sex\",\"value\":2}],\"tooltip\":\"The compatibility report shows love potential between you and your partner\"}},{\"date\":\"2026-03-02\",\"status\":\"unfavorable\"}]"
