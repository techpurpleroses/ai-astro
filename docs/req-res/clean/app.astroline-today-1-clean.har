            "text": "{\"birth\":{\"date\":\"2000-01-01\",\"time\":\"19:25\",\"location\":{\"name\":\"Bharuch, Gujarat, India\",\"lat\":21.7080427,\"lon\":72.9956936}},\"current\":{\"date\":\"2026-02-28\",\"time\":\"10:18\",\"location\":{\"name\":\"Asia/Kolkata\",\"lat\":19.0748,\"lon\":72.8856}}}"
