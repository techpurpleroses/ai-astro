            "size": 2363,
            "mimeType": "application/json",
            "text": "{\"data\":{\"user_reports\":[{\"resource_type\":\"Report\",\"id\":6602137,\"product_code\":\"soulmate\",\"title\":\"Soulmate Sketch\",\"image\":\"https://astroline.b-cdn.net/report_icons/sketch.png\",\"link\":\"soulmate\",\"view_type\":\"app_section\",\"is_pdf\":false,\"type_of_issue\":\"sub_gift\",\"ready_timer\":0,\"speed_up\":null},{\"resource_type\":\"Report\",\"id\":6602185,\"product_code\":\"horoscope\",\"title\":\"Prediction 2026 Report\",\"image\":\"https://astroline.b-cdn.net/report_icons/horoscope.png\",\"link\":\"https://year-forecast.astroline.today/?idfm=80cb6ec0-f885-11f0-8530-bdc4cb22a3e1&sign=capricorn\",\"view_type\":\"online\",\"is_pdf\":false,\"type_of_issue\":\"gift\",\"ready_timer\":0,\"speed_up\":null}],\"available_reports\":[\"compatibility\",\"birth_chart\",\"horoscope\",\"moon\",\"soulmate\",\"witch_type\"],\"detailed_available_reports\":[{\"resource_type\":\"ReportAvailable\",\"product_code\":\"palm_reading\",\"title\":\"Palm Reading Report\",\"image\":\"https://astroline.b-cdn.net/report_icons/palm-reading.png\",\"view_type\":\"app_section\",\"is_pdf\":false},{\"resource_type\":\"ReportAvailable\",\"product_code\":\"compatibility\",\"title\":\"Compatibility Report\",\"image\":\"https://astroline.b-cdn.net/report_icons/compatibility.png\",\"view_type\":\"online\",\"is_pdf\":true},{\"resource_type\":\"ReportAvailable\",\"product_code\":\"birth_chart\",\"title\":\"Birth Chart Report\",\"image\":\"https://astroline.b-cdn.net/report_icons/birth-chart.png\",\"view_type\":\"online\",\"is_pdf\":true},{\"resource_type\":\"ReportAvailable\",\"product_code\":\"astrocartography\",\"title\":\"Astrocartography Report\",\"image\":\"https://astroline.b-cdn.net/report_icons/astrocartography.png\",\"view_type\":\"online\",\"is_pdf\":true},{\"resource_type\":\"ReportAvailable\",\"product_code\":\"horoscope\",\"title\":\"Prediction 2026 Report\",\"image\":\"https://astroline.b-cdn.net/report_icons/horoscope.png\",\"view_type\":\"online\",\"is_pdf\":false},{\"resource_type\":\"ReportAvailable\",\"product_code\":\"moon\",\"title\":\"Moon Report\",\"image\":\"https://astroline.b-cdn.net/report_icons/moon.png\",\"view_type\":\"online\",\"is_pdf\":false},{\"resource_type\":\"ReportAvailable\",\"product_code\":\"soulmate\",\"title\":\"Soulmate Sketch\",\"image\":\"https://astroline.b-cdn.net/report_icons/sketch.png\",\"view_type\":\"app_section\",\"is_pdf\":false},{\"resource_type\":\"ReportAvailable\",\"product_code\":\"witch_type\",\"title\":\"Witch Type Report\",\"image\":\"https://astroline.b-cdn.net/report_icons/witch_type.png\",\"view_type\":\"app_section\",\"is_pdf\":false}]}}"
