          "content": {
            "size": 4978,
            "mimeType": "application/json",
            "text": "{\"love\":{\"id\":1,\"title\":\"Love\",\"slug\":\"love\",\"priority\":1,\"questions\":{\"1\":{\"text\":\"When will I find my soulmate?\",\"type\":null},\"4\":{\"text\":\"Does my partner love me?\",\"type\":null},\"7\":{\"text\":\"How do I find my true love?\",\"type\":null},\"10\":{\"text\":\"Are we going to be together?\",\"type\":null},\"13\":{\"text\":\"Should I get back with my ex?\",\"type\":null},\"16\":{\"text\":\"Will my ex call me?\",\"type\":null},\"19\":{\"text\":\"Is my partner cheating on me?\",\"type\":null},\"22\":{\"text\":\"Should I break up with him?\",\"type\":null},\"25\":{\"text\":\"Are we destined to be together?\",\"type\":null},\"28\":{\"text\":\"Are we going to get married?\",\"type\":null}}},\"future\":{\"id\":4,\"title\":\"Future\",\"slug\":\"future\",\"priority\":2,\"questions\":{\"31\":{\"text\":\"What does the future hold for me?\",\"type\":null},\"34\":{\"text\":\"Will I achieve my goals this year?\",\"type\":null},\"37\":{\"text\":\"Am I likely to get in money trouble?\",\"type\":null},\"40\":{\"text\":\"Am I likely to lose a job soon?\",\"type\":null},\"43\":{\"text\":\"When will I get married?\",\"type\":null},\"46\":{\"text\":\"When will I have a baby?\",\"type\":null},\"52\":{\"text\":\"Will I succeed in my career?\",\"type\":null},\"55\":{\"text\":\"When will I become financially secure?\",\"type\":null},\"218\":{\"text\":\"Can you read my palm lines?\",\"type\":\"palmRequestSuggest\"}}},\"career\":{\"id\":7,\"title\":\"Career\",\"slug\":\"career\",\"priority\":3,\"questions\":{\"61\":{\"text\":\"Can you predict my career path?\",\"type\":null},\"64\":{\"text\":\"Am I on the right career path?\",\"type\":null},\"67\":{\"text\":\"Should I look for a better job?\",\"type\":null},\"70\":{\"text\":\"Is it a good time to ask for a raise?\",\"type\":null},\"73\":{\"text\":\"When will I get a promotion?\",\"type\":null},\"76\":{\"text\":\"Will I find a new job soon?\",\"type\":null},\"79\":{\"text\":\"Will I be happ