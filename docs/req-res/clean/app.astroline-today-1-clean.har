          "content": {
            "size": 7357,
            "mimeType": "application/json",
            "text": "[{\"date\":\"2026-02-26\",\"sign\":\"cancer\",\"phase\":{\"id\":33,\"moon_phase\":\"waxing-gibbous\",\"lang_id\":1,\"name\":\"Waxing Gibbous Moon\",\"description\":\"The Waxing Gibbous Moon occurs when the Moon is more than half full and growing brighter each night. In astrology, it’s a time for refining your goals, staying focused, and making improvements before reaching a peak or result.\"},\"ritual\":{\"item\":{\"id\":12,\"moon_phase\":\"waxing-gibbous\",\"day_number\":null,\"lang_id\":\"1\",\"name\":\"Visit a hairdresser\",\"description\":\"Cutting your hair during the Waxing Moon helps it grow faster, stronger, and healthier.\"},\"tooltip\":\"Reading a birth chart illuminates aspects of your life, both conscious and unconscious\"},\"moon_in_sign\":[{\"id\":33,\"is_positive\":true,\"content\":\"Now is a great time to try new recipes and explore creative cooking ideas.\"},{\"id\":42,\"is_positive\":false,\"content\":\"Keep your promises now, as breaking your word could harm your reputation later.\"}],\"overview\":[{\"id\":48,\"day_number\":9,\"lang_id\":1,\"content\":\"Bat\",\"name\":\"Symbol of the day\",\"slug\":\"symbol\"},{\"id\":49,\"day_number\":9,\"lang_id\":1,\"content\":\"Have a solid grain porridge\",\"name\":\"Health\",\"slug\":\"health\"},{\"id\":50,\"day_number\":9,\"lang_id\":1,\"content\":\"Breast-centered energy\",\"name\":\"Body\",\"slug\":\"body\"},{\"id\":51,\"day_number\":9,\"lang_id\":1,\"content\":\"Do a clay mask\",\"name\":\"Beauty\",\"slug\":\"beauty\"},{\"id\":52,\"day_number\":9,\"lang_id\":1,\"content\":\"Remove old, unused items\",\"name\":\"Happy house\",\"slug\":\"happy_house\"}]},{\"date\":\"2026-02-27\",\"sign\":\"cancer\",\"phase\":{\"id\":37,\"moon_phase\":\"waxing-gibbous\",\"lang_id\":1,\"name\":\"Waxing Gibbous Moon\",\"description\":\"This phase might bring feelings of loneliness or a lack of support. However, it also holds strong creative energy, which you can use to help yourself and support others, as many people are feeling the same way.\"},\"ritual\":{\"item\":{\"id\":11,\"moon_phase\":\"waxing-gibbous\",\"day_number\":null,\"lang_id\":\"1\",\"name\":\"Solve financial issues\",\"description\":\"It is a good time to borrow, invest, or take a loan, as it can lead to long-term gains.\"},\"tooltip\":\"Reading a birth chart illuminates aspects of your life, both conscious and unconscious\"},\"moon_in_sign\":[{\"id\":37,\"is_positive\":true,\"content\":\"Spend time by water or with loved ones now, as this period supports both relaxation and deeper bonds.\"},{\"id\":41,\"is_positive\":false,\"content\":\"Fight selfish urges now and support your loved ones, as the pull to take without giving is strong.\"}],\"overview\":[{\"id\":53,\"day_number\":10,\"lang_id\":1,\"content\":\"Waterfall\",\"name\":\"Symbol of the day\",\"slug\":\"symbol\"},{\"id\":54,\"day_number\":10,\"lang_id\":1,\"content\":\"Try fasting\",\"name\":\"Health\",\"slug\":\"health\"},{\"id\":55,\"day_number\":10,\"lang_id\":1,\"content\":\"Chest bones-centered energy\",\"name\":\"Body\",\"slug\":\"body\"},{\"id\":56,\"day_number\":10,\"lang_id\":1,\"content\":\"Work on posture\",\"name\":\"Beauty\",\"slug\":\"beauty\"},{\"id\":57,\"day_number\":10,\"lang_id\":1,\"content\":\"Start repairs\",\"name\":\"Happy house\",\"slug\":\"happy_house\"}]},{\"date\":\"2026-02-28\",\"sign\":\"cancer\",\"phase\":{\"id\":39,\"moon_phase\":\"waxing-gibbous\",\"lang_id\":1,\"name\":\"Waxing Gibbous Moon\",\"description\":\"During this Moon phase, it’s easy to become a perfectionist, which can make you feel worse about mistakes or setbacks. Try to be kinder to yourself and not expect too much from others.\"},\"ritual\":{\"item\":{\"id\":12,\"moon_phase\":\"waxing-gibbous\",\"day_number\":null,\"lang_id\":\"1\",\"name\":\"Visit a hairdresser\",\"description\":\"Cutting your hair during the Waxing Moon helps it grow faster, stronger, and healthier.\"},\"tooltip\":\"Reading a birth chart illuminates aspects of your life, both conscious and unconscious\"},\"moon_in_sign\":[{\"id\":36,\"is_positive\":true,\"content\":\"Start yoga, meditation, or self-growth courses now, as the period supports inner balance.\"},{\"id\":40,\"is_positive\":false,\"content\":\"Avoid emotionally draining tasks now, as too much stress can harm your mental well-being.\"}],\"overview\":[{\"id\":58,\"day_number\":11,\"lang_id\":1,\"content\":\"Labyrinth\",\"name\":\"Symbol of the day\",\"slug\":\"symbol\"},{\"id\":59,\"day_number\":11,\"lang_id\":1,\"content\":\"Do a power yoga\",\"name\":\"Health\",\"slug\":\"health\"},{\"id\":60,\"day_number\":11,\"lang_id\":1,\"content\":\"Backbone-centered energy\",\"name\":\"Body\",\"slug\":\"body\"},{\"id\":61,\"day_number\":11,\"lang_id\":1,\"content\":\"Use vitamin C\",\"name\":\"Beauty\",\"slug\":\"beauty\"},{\"id\":62,\"day_number\":11,\"lang_id\":1,\"content\":\"Reorganize your workspace\",\"name\":\"Happy house\",\"slug\":\"happy_house\"}]},{\"date\":\"2026-03-01\",\"sign\":\"cancer\",\"phase\":{\"id\":41,\"moon_phase\":\"waxing-gibbous\",\"lang_id\":1,\"name\":\"Waxing Gibbous Moon\",\"description\":\"The Waxing Gibbous Moon boosts focus and refinement. During this phase, you can feel more motivated to perform tasks, review plans, and make final adjustments before moving forward.\"},\"ritual\":{\"item\":{\"id\":12,\"moon_phase\":\"waxing-gibbous\",\"day_number\":null,\"lang_id\":\"1\",\"name\":\"Visit a hairdresser\",\"description\":\"Cutting your hair during the Waxing Moon helps it grow faster, stronger, and healthier.\"},\"tooltip\":\"Reading a birth chart illuminates aspects of your life, both conscious and unconscious\"},\"moon_in_sign\":[{\"id\":37,\"is_positive\":true,\"content\":\"Spend time by water or with loved ones now, as this period supports both relaxation and deeper bonds.\"},{\"id\":39,\"is_positive\":false,\"content\":\"Delay non-urgent digestive treatments now, unless surgery is needed.\"}],\"overview\":[{\"id\":63,\"day_number\":12,\"lang_id\":1,\"content\":\"Heart\",\"name\":\"Symbol of the day\",\"slug\":\"symbol\"},{\"id\":64,\"day_number\":12,\"lang_id\":1,\"content\":\"Drink herbal tea\",\"name\":\"Health\",\"slug\":\"health\"},{\"id\":65,\"day_number\":12,\"lang_id\":1,\"content\":\"Heart-centered energy\",\"name\":\"Body\",\"slug\":\"body\"},{\"id\":66,\"day_number\":12,\"lang_id\":1,\"content\":\"Do a calming treatment\",\"name\":\"Beauty\",\"slug\":\"beauty\"},{\"id\":67,\"day_number\":12,\"lang_id\":1,\"content\":\"Plant a flower\",\"name\":\"Happy house\",\"slug\":\"happy_house\"}]},{\"date\":\"2026-03-02\",\"sign\":\"cancer\",\"phase\":{\"id\":34,\"moon_phase\":\"waxing-gibbous\",\"lang_id\":1,\"name\":\"Waxing Gibbous Moon\",\"description\":\"The Gibbous Moon represents a time of growth and improvement, when you may reflect on your actions and choices. While you may feel pressure to make quick decisions, it’s better to stay patient and thoughtful during this phase.\"},\"ritual\":{\"item\":{\"id\":12,\"moon_phase\":\"waxing-gibbous\",\"day_number\":null,\"lang_id\":\"1\",\"name\":\"Visit a hairdresser\",\"description\":\"Cutting your hair during the Waxing Moon helps it grow faster, stronger, and healthier.\"},\"tooltip\":\"Reading a birth chart illuminates aspects of your life, both conscious and unconscious\"},\"moon_in_sign\":[{\"id\":33,\"is_positive\":true,\"content\":\"Now is a great time to try new recipes and explore creative cooking ideas.\"},{\"id\":39,\"is_positive\":false,\"content\":\"Delay non-urgent digestive treatments now, unless surgery is needed.\"}],\"overview\":[{\"id\":68,\"day_number\":13,\"lang_id\":1,\"content\":\"Spinning wheel\",\"name\":\"Symbol of the day\",\"slug\":\"symbol\"},{\"id\":69,\"day_number\":13,\"lang_id\":1,\"content\":\"Try a seafood dish\",\"name\":\"Health\",\"slug\":\"health\"},{\"id\":70,\"day_number\":13,\"lang_id\":1,\"content\":\"Pancreas-centered energy\",\"name\":\"Body\",\"slug\":\"body\"},{\"id\":71,\"day_number\":13,\"lang_id\":1,\"content\":\"Do a face massage\",\"name\":\"Beauty\",\"slug\":\"beauty\"},{\"id\":72,\"day_number\":13,\"lang_id\":1,\"content\":\"Water your plants\",\"name\":\"Happy house\",\"slug\":\"happy_house\"}]}]"
